# Variables de entorno para el backend (Hono)
# -------------------------------------------

# NODE_ENV: Entorno de la aplicación. Puede ser 'development' o 'production'.
# Determina el comportamiento de logging y otras configuraciones específicas del entorno.
NODE_ENV=development

# PORT: Puerto en el que se ejecutará el servidor del backend.
# Valor por defecto: 3001
PORT=3001

# DATABASE_URL: Cadena de conexión a la base de datos PostgreSQL.
# Ejemplo para desarrollo local: postgresql://user:password@localhost:5432/mercanto
DATABASE_URL=postgresql://user:password@localhost:5432/mercanto

# LOG_LEVEL: Nivel de logging para el backend (e.g., 'debug', 'info', 'warn', 'error').
# Valor por defecto: 'info'
LOG_LEVEL=debug

# CORS_ORIGIN: Origen permitido para las solicitudes CORS.
# En desarrollo, suele ser la URL del frontend. En producción, debe ser la URL de tu dominio.
# Valor por defecto: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# JWT_SECRET: Clave secreta para firmar y verificar JSON Web Tokens.
# ¡IMPORTANTE! Cambia este valor por una cadena aleatoria y segura en producción.
# Valor por defecto: 'mercanto_secret_key'
JWT_SECRET=mercanto_secret_key
