# ==========================================
# MERCANTOAPP - CONFIGURACIÓN DE ENTORNO
# ==========================================

# --- Servidor y Despliegue ---
# El puerto en el que correrá el servidor (Render usa PORT por defecto)
PORT=10000
# La ruta base para el despliegue (ej: / o /app/)
BASE_PATH=/
# Entorno de ejecución (development, production, test)
NODE_ENV=production

# --- Base de Datos ---
# URL de conexión a PostgreSQL (Neon, Supabase, Local, etc.)
# Formato: postgresql://usuario:password@host:puerto/nombre_db?sslmode=require
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# --- Frontend (Vite) ---
# Si necesitas apuntar a una API específica desde el cliente
# VITE_API_URL=https://tu-api.render.com/api

# --- Seguridad ---
# Secreto para la firma de tokens JWT (si aplica)
# JWT_SECRET=tu_secreto_super_seguro_aqui
